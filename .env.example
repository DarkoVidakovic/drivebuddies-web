# Google Places API (New) — used at build time to fetch live rating + review count.
# Without these, the site builds with fallback hardcoded values.
#
# 1. Create a project at https://console.cloud.google.com
# 2. Enable "Places API (New)"
# 3. Create an API key and restrict it to the Places API
# 4. Find the Place ID at https://developers.google.com/maps/documentation/javascript/examples/places-placeid-finder
#    Search for "Drive Buddies Fahrschule" — it starts with "ChIJ…"

GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
