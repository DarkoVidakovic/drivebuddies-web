---
import { useTranslations, getAlternatePath, type Locale } from '../i18n/index.ts';
import { route } from '../i18n/routes.ts';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const altPath = getAlternatePath(Astro.url.pathname, locale);

const prefix = locale === 'en' ? '/en' : '';

type NavLink = { href: string; label: string };
type NavGroup = { label: string; children: NavLink[] };
type NavItem = NavLink | NavGroup;

const links: NavItem[] = [
  { href: route('services', locale), label: t.nav.services },
  {
    label: t.nav.ausbildung,
    children: [
      { href: route('courses', locale), label: t.nav.courses },
      { href: route('learnerLicence', locale), label: t.nav.learnerLicence },
      { href: route('drivingLicence', locale), label: t.nav.licence },
      { href: route('twoPhase', locale), label: t.nav.twoPhase },
      { href: route('kontrollfahrt', locale), label: t.nav.kontrollfahrt },
    ],
  },
  { href: route('about', locale), label: t.nav.about },
  { href: route('prices', locale), label: t.nav.prices },
  { href: route('blog', locale), label: t.nav.blog },
  { href: route('contact', locale), label: t.nav.contact },
];

const current = Astro.url.pathname;

function isGroup(item: NavItem): item is NavGroup {
  return 'children' in item;
}

function isGroupActive(item: NavGroup): boolean {
  return item.children.some((c) => c.href === current);
}
---

<header class="nav">
  <div class="nav__inner">
    <a href={`${prefix}/`} class="nav__brand" aria-label="DriveBuddies Home">
      <img src="/logo.svg" alt="DriveBuddies" class="nav__logo" width="156" height="41" />
    </a>

    <button
      class="nav__toggle"
      type="button"
      aria-expanded="false"
      aria-controls="nav-menu"
      aria-label={t.nav.openMenu}
      data-nav-toggle
    >
      <span class="nav__toggle-bar"></span>
      <span class="nav__toggle-bar"></span>
      <span class="nav__toggle-bar"></span>
    </button>

    <nav class="nav__menu" id="nav-menu" aria-label="Hauptnavigation" data-nav-menu>
      <ul class="nav__list">
        {
          links.map((item) =>
            isGroup(item) ? (
              <li class="nav__item nav__item--group" data-dropdown>
                <button
                  class:list={['nav__link', 'nav__group-toggle', isGroupActive(item) && 'nav__link--active']}
                  aria-expanded="false"
                  aria-haspopup="list"
                  data-dropdown-toggle
                >
                  {item.label}
                  <svg class="nav__chevron" viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M4 6l4 4 4-4" />
                  </svg>
                </button>
                <ul class="nav__dropdown" role="list" data-dropdown-menu>
                  {item.children.map((child) => (
                    <li>
                      <a
                        href={child.href}
                        class="nav__dropdown-link"
                        aria-current={current === child.href ? 'page' : undefined}
                      >
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </li>
            ) : (
              <li class="nav__item">
                <a
                  href={item.href}
                  class="nav__link"
                  aria-current={current === item.href ? 'page' : undefined}
                >
                  {item.label}
                </a>
              </li>
            )
          )
        }
      </ul>
      <a href={altPath} class="nav__lang" hreflang={locale === 'de' ? 'en' : 'de'}>
        {t.nav.switchLang}
      </a>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
  }

  .nav__inner {
    max-width: 1200px;
    margin-inline: auto;
    padding: var(--space-4) var(--space-6);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
  }

  .nav__brand {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .nav__logo {
    height: 40px;
    width: auto;
    display: block;
  }

  .nav__menu {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    min-width: 0;
  }

  .nav__list {
    display: flex;
    align-items: center;
    flex-wrap: nowrap;
    gap: var(--space-4);
    list-style: none;
    margin: 0;
    padding: 0;
    min-width: 0;
  }

  .nav__item {
    position: relative;
  }

  .nav__link {
    color: var(--color-text);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.875rem;
    white-space: nowrap;
    padding-block: var(--space-1);
    border-bottom: 2px solid transparent;
    transition: color 0.15s, border-color 0.15s;
    background: none;
    border-top: none;
    border-left: none;
    border-right: none;
    cursor: pointer;
    font-family: inherit;
    padding-inline: 0;
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
  }

  .nav__link:hover,
  .nav__link:focus-visible {
    color: var(--color-primary);
  }

  .nav__link[aria-current='page'],
  .nav__link--active {
    color: var(--color-primary);
    border-bottom-color: var(--color-primary);
  }

  /* Chevron */
  .nav__chevron {
    transition: transform 0.2s;
    flex-shrink: 0;
  }

  .nav__item--group[data-open] .nav__chevron {
    transform: rotate(180deg);
  }

  /* Dropdown panel */
  .nav__dropdown {
    position: absolute;
    top: calc(100% + var(--space-3));
    left: 50%;
    translate: -50% 0;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
    min-width: 220px;
    padding: var(--space-2) 0;
    list-style: none;
    margin: 0;
    z-index: 100;
    visibility: hidden;
    opacity: 0;
    transition: opacity 0.15s, visibility 0.15s;
  }

  .nav__item--group[data-open] > .nav__dropdown {
    visibility: visible;
    opacity: 1;
  }

  .nav__dropdown-link {
    display: block;
    padding: var(--space-3) var(--space-6);
    color: var(--color-text);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    white-space: nowrap;
    transition: background 0.1s, color 0.1s;
  }

  .nav__dropdown-link:hover,
  .nav__dropdown-link:focus-visible {
    background: var(--color-surface-alt);
    color: var(--color-primary);
  }

  .nav__dropdown-link[aria-current='page'] {
    color: var(--color-primary);
    font-weight: 600;
    background: color-mix(in srgb, var(--color-primary) 6%, var(--color-surface));
  }

  .nav__lang {
    color: var(--color-primary);
    font-weight: 600;
    font-size: 0.9375rem;
    text-decoration: none;
    padding: var(--space-1) var(--space-3);
    border: 1px solid var(--color-primary);
    border-radius: var(--radius-full);
    transition: background 0.15s, color 0.15s;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .nav__lang:hover,
  .nav__lang:focus-visible {
    background: var(--color-primary);
    color: var(--color-surface);
  }

  .nav__toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-2);
  }

  .nav__toggle-bar {
    display: block;
    height: 2px;
    width: 24px;
    background: var(--color-text);
    border-radius: var(--radius-full);
    transition: transform 0.2s, opacity 0.2s;
  }

  .nav__toggle[aria-expanded='true'] .nav__toggle-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav__toggle[aria-expanded='true'] .nav__toggle-bar:nth-child(2) {
    opacity: 0;
  }
  .nav__toggle[aria-expanded='true'] .nav__toggle-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ── Mobile ── */
  @media (max-width: 1100px) {
    .nav__toggle {
      display: flex;
    }

    .nav__menu {
      position: fixed;
      inset: 64px 0 0 0;
      flex-direction: column;
      align-items: stretch;
      gap: var(--space-4);
      background: var(--color-surface);
      padding: var(--space-6);
      transform: translateX(100%);
      transition: transform 0.25s ease;
      overflow-y: auto;
      z-index: 49;
    }

    .nav__menu[data-open] {
      transform: translateX(0);
    }

    .nav__list {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
    }

    .nav__item {
      position: static;
    }

    .nav__link {
      display: flex;
      justify-content: space-between;
      padding: var(--space-3) 0;
      border-bottom: 1px solid var(--color-border);
      border-top: none;
      border-left: none;
      border-right: none;
      width: 100%;
    }

    /* On mobile, always show the dropdown items (no visibility toggle needed) */
    .nav__dropdown {
      position: static;
      translate: none;
      border: none;
      border-radius: 0;
      box-shadow: none;
      padding: 0;
      min-width: 0;
      visibility: visible;
      opacity: 1;
      transition: none;
      background: var(--color-surface-alt);
      display: none;
    }

    .nav__item--group[data-open] > .nav__dropdown {
      display: block;
    }

    .nav__chevron {
      display: block;
    }

    .nav__dropdown-link {
      padding: var(--space-3) var(--space-6);
      border-bottom: 1px solid var(--color-border);
      font-size: 0.875rem;
    }

    .nav__dropdown-link:last-child {
      border-bottom: none;
    }

    .nav__lang {
      text-align: center;
      margin-top: var(--space-4);
    }
  }
</style>

<script>
  // Main menu toggle
  const toggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
  const menu = document.querySelector<HTMLElement>('[data-nav-menu]');

  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const open = menu.hasAttribute('data-open');
      if (open) {
        menu.removeAttribute('data-open');
        toggle.setAttribute('aria-expanded', 'false');
      } else {
        menu.setAttribute('data-open', '');
        toggle.setAttribute('aria-expanded', 'true');
      }
    });
  }

  // Dropdown groups
  function closeAllDropdowns(except?: Element) {
    document.querySelectorAll<HTMLElement>('[data-dropdown]').forEach((el) => {
      if (el === except) return;
      el.removeAttribute('data-open');
      const btn = el.querySelector<HTMLButtonElement>('[data-dropdown-toggle]');
      if (btn) btn.setAttribute('aria-expanded', 'false');
    });
  }

  document.querySelectorAll<HTMLElement>('[data-dropdown]').forEach((group) => {
    const btn = group.querySelector<HTMLButtonElement>('[data-dropdown-toggle]');
    if (!btn) return;

    btn.addEventListener('click', () => {
      const isOpen = group.hasAttribute('data-open');
      closeAllDropdowns(group);
      if (isOpen) {
        group.removeAttribute('data-open');
        btn.setAttribute('aria-expanded', 'false');
      } else {
        group.setAttribute('data-open', '');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });

  // Close on outside click
  document.addEventListener('click', (e) => {
    if (!(e.target as Element).closest('[data-dropdown]')) {
      closeAllDropdowns();
    }
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeAllDropdowns();
  });
</script>
