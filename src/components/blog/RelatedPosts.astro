---
import type { CollectionEntry } from 'astro:content';
import PostCard from './PostCard.astro';

interface Props {
  currentId: string;
  currentTags: string[];
  allPosts: CollectionEntry<'blog'>[];
  lang?: 'de' | 'en';
  maxPosts?: number;
}

const { currentId, currentTags, allPosts, lang = 'de', maxPosts = 3 } = Astro.props;

const related = allPosts
  .filter((p) => p.id !== currentId && !p.data.draft)
  .map((p) => ({
    post: p,
    score: p.data.tags.filter((t) => currentTags.includes(t)).length,
  }))
  .filter(({ score }) => score > 0)
  .sort((a, b) => b.score - a.score || b.post.data.date.getTime() - a.post.data.date.getTime())
  .slice(0, maxPosts)
  .map(({ post }) => post);

const heading = lang === 'en' ? 'Related articles' : 'Verwandte Artikel';
---

{related.length > 0 && (
  <section class="related" aria-label={heading}>
    <h2 class="related__heading">{heading}</h2>
    <div class="related__grid">
      {related.map((post) => <PostCard post={post} lang={lang} />)}
    </div>
  </section>
)}

<style>
  .related {
    margin-top: var(--space-16);
    padding-top: var(--space-12);
    border-top: 1px solid var(--color-border);
  }

  .related__heading {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: var(--space-8);
    color: var(--color-text);
  }

  .related__grid {
    display: grid;
    gap: var(--space-6);
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }
</style>
