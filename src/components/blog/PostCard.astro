---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
  lang?: 'de' | 'en';
}

const { post, lang = 'de' } = Astro.props;
const { title, description, date, tags, cover, author } = post.data;

const slug = post.id.replace(/^en\//, '');
const href = lang === 'en' ? `/en/blog/${slug}/` : `/blog/${slug}/`;

const formattedDate = date.toLocaleDateString(lang === 'en' ? 'en-GB' : 'de-CH', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const wordCount = post.body?.split(/\s+/).length ?? 0;
const readingMinutes = Math.max(1, Math.ceil(wordCount / 200));
const readingLabel = lang === 'en'
  ? `${readingMinutes} min read`
  : `${readingMinutes} Min. Lesezeit`;
---

<article class="post-card">
  {cover && (
    <a href={href} class="post-card__cover-link" tabindex="-1" aria-hidden="true">
      <img
        src={cover}
        alt=""
        class="post-card__cover"
        loading="lazy"
        decoding="async"
        width="800"
        height="450"
      />
    </a>
  )}
  <div class="post-card__body">
    {tags.length > 0 && (
      <ul class="post-card__tags" aria-label={lang === 'en' ? 'Tags' : 'Schlagwörter'}>
        {tags.map((tag) => (
          <li>
            <a
              href={lang === 'en' ? `/en/blog/tags/${encodeURIComponent(tag)}/` : `/blog/tags/${encodeURIComponent(tag)}/`}
              class="post-card__tag"
            >
              {tag}
            </a>
          </li>
        ))}
      </ul>
    )}
    <h2 class="post-card__title">
      <a href={href}>{title}</a>
    </h2>
    <p class="post-card__desc">{description}</p>
    <footer class="post-card__meta">
      {author && <span class="post-card__author">{author}</span>}
      <time datetime={date.toISOString()} class="post-card__date">{formattedDate}</time>
      <span class="post-card__reading">{readingLabel}</span>
    </footer>
  </div>
</article>

<style>
  .post-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: box-shadow 0.2s ease, transform 0.2s ease;
    display: flex;
    flex-direction: column;
  }

  .post-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .post-card__cover-link {
    display: block;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .post-card__cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .post-card:hover .post-card__cover {
    transform: scale(1.03);
  }

  .post-card__body {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1;
  }

  .post-card__tags {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .post-card__tag {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary);
    text-decoration: none;
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
  }

  .post-card__tag:hover {
    background: color-mix(in srgb, var(--color-primary) 20%, transparent);
  }

  .post-card__title {
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.35;
    margin: 0;
  }

  .post-card__title a {
    color: var(--color-text);
    text-decoration: none;
  }

  .post-card__title a:hover {
    color: var(--color-primary);
  }

  .post-card__desc {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }

  .post-card__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin-top: auto;
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-border);
  }

  .post-card__author {
    font-weight: 600;
    color: var(--color-text);
  }

  .post-card__author::after {
    content: '·';
    margin-left: var(--space-2);
    color: var(--color-border);
  }

  .post-card__reading::before {
    content: '·';
    margin-right: var(--space-2);
    color: var(--color-border);
  }
</style>
