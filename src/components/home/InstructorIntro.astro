---
import Section from '../ui/Section.astro';
import Button from '../ui/Button.astro';
import Icon from '../ui/Icon.astro';
import { useTranslations, type Locale } from '../../i18n/index.ts';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const i = t.home.instructor;

const aboutHref = locale === 'en' ? '/en/about/' : '/ueber-uns/';
---

<Section variant="alt">
  <div class="instructor">
    <div class="instructor__media" aria-hidden="true">
      <span class="instructor__avatar">
        <Icon name="instructor" />
      </span>
    </div>
    <div class="instructor__body">
      <p class="instructor__eyebrow">{i.eyebrow}</p>
      <h2 class="instructor__name">{i.name}</h2>
      <p class="instructor__role">{i.role}</p>
      <p class="instructor__text">{i.text}</p>
      <Button href={aboutHref} variant="secondary">{i.cta}</Button>
    </div>
  </div>
</Section>

<style>
  .instructor {
    display: grid;
    gap: var(--space-12);
    align-items: center;
  }

  .instructor__media {
    display: flex;
    justify-content: center;
  }

  .instructor__avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 180px;
    height: 180px;
    border-radius: var(--radius-full);
    background: color-mix(in srgb, var(--color-primary) 12%, var(--color-surface));
    color: var(--color-primary);
    box-shadow: var(--shadow-md);
  }

  .instructor__avatar :global(.icon) {
    width: 96px;
    height: 96px;
  }

  .instructor__eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
    margin: 0 0 var(--space-3);
  }

  .instructor__name {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    margin-bottom: var(--space-2);
  }

  .instructor__role {
    color: var(--color-text-muted);
    font-weight: 600;
    margin: 0 0 var(--space-6);
  }

  .instructor__text {
    color: var(--color-text-muted);
    font-size: 1.125rem;
    margin: 0 0 var(--space-8);
    max-width: 60ch;
  }

  @media (min-width: 768px) {
    .instructor {
      grid-template-columns: auto 1fr;
    }
  }
</style>
