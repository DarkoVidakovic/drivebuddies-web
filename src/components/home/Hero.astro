---
import Button from '../ui/Button.astro';
import WhatsAppButton from '../ui/WhatsAppButton.astro';
import { useTranslations, type Locale } from '../../i18n/index.ts';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const h = t.home.hero;

const coursesHref = locale === 'en' ? '/en/courses/' : '/kurse/';
const whatsappMsg =
  locale === 'en'
    ? 'Hi DriveBuddies, I would like to learn more about your driving lessons.'
    : 'Hallo DriveBuddies, ich möchte mehr über eure Fahrstunden erfahren.';
---

<section class="hero section--default" data-wa-hide-sentinel>
  <div class="hero__scene" aria-hidden="true">
    <div class="hero__horizon"></div>
    <div class="hero__floor"></div>
  </div>
  <div class="hero__inner">
    <p class="hero__eyebrow">{h.eyebrow}</p>
    <h1 class="hero__title">{h.title}</h1>
    <p class="hero__subtitle">{h.subtitle}</p>
    <div class="hero__actions">
      <Button href={coursesHref} size="lg">{h.ctaPrimary}</Button>
      <WhatsAppButton label={h.ctaWhatsapp} size="lg" variant="secondary" message={whatsappMsg} />
    </div>
    <p class="hero__trust">{h.trust}</p>
  </div>
</section>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-primary) 6%, var(--color-surface)) 0%,
      var(--color-surface) 48%
    );
    padding: var(--space-20) var(--space-6);
  }

  /* ── Abstract perspective grid: the road ahead, receding to a
        vanishing point behind the headline ──────────────────────────── */
  .hero__scene {
    position: absolute;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    perspective: 340px;
    perspective-origin: 50% 0%;
    pointer-events: none;
  }

  /* Soft glow blooming from the vanishing point on the horizon line. */
  .hero__horizon {
    position: absolute;
    left: 50%;
    top: 46%;
    width: 70%;
    height: 40%;
    transform: translate(-50%, -50%);
    background: radial-gradient(
      ellipse at center,
      color-mix(in srgb, var(--color-primary) 28%, transparent) 0%,
      transparent 68%
    );
    opacity: 0.9;
  }

  .hero__floor {
    position: absolute;
    left: -50%;
    right: -50%;
    bottom: -2%;
    height: 88%;
    transform: rotateX(80deg);
    transform-origin: 50% 100%;
    background-image:
      repeating-linear-gradient(
        0deg,
        color-mix(in srgb, var(--color-primary) 24%, transparent) 0 1px,
        transparent 1px 46px
      ),
      repeating-linear-gradient(
        90deg,
        color-mix(in srgb, var(--color-primary) 20%, transparent) 0 1px,
        transparent 1px 46px
      );
    background-position:
      0 0,
      0 0;
    /* Fade the far lines into the horizon, and the side edges outward. */
    -webkit-mask-image:
      linear-gradient(to top, #000 6%, transparent 62%),
      linear-gradient(to right, transparent, #000 18%, #000 82%, transparent);
    mask-image:
      linear-gradient(to top, #000 6%, transparent 62%),
      linear-gradient(to right, transparent, #000 18%, #000 82%, transparent);
    -webkit-mask-composite: source-in;
    mask-composite: intersect;
    animation: hero-road 2.4s linear infinite;
    will-change: background-position;
  }

  .hero__inner {
    position: relative;
    max-width: 1200px;
    margin-inline: auto;
    text-align: center;
  }

  .hero__eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
    margin: 0 0 var(--space-4);
  }

  .hero__title {
    font-size: clamp(2.25rem, 6vw, 4rem);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 auto var(--space-6);
    max-width: 18ch;
  }

  .hero__subtitle {
    font-size: clamp(1.0625rem, 2vw, 1.375rem);
    color: var(--color-text-muted);
    max-width: 60ch;
    margin: 0 auto var(--space-8);
  }

  .hero__actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero__trust {
    margin: var(--space-8) 0 0;
    font-size: 0.9375rem;
    color: var(--color-text-muted);
  }

  /* Horizontal grid lines (first background layer) flow toward the
     viewer; vertical lines (second layer) stay anchored. */
  @keyframes hero-road {
    from { background-position: 0 0, 0 0; }
    to { background-position: 0 46px, 0 0; }
  }

  @media (min-width: 768px) {
    .hero {
      padding: var(--space-24) var(--space-8);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__floor {
      animation: none;
    }
  }
</style>
