---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import RelatedPosts from '../../components/blog/RelatedPosts.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.lang === 'de' && !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { title, description, date, tags, cover, author, lang } = post.data;
const { Content } = await render(post);

const site = 'https://drivebuddies.ch';
const canonical = `${site}/blog/${post.id}/`;
const enSlug = post.id; // same slug for EN version

const formattedDate = date.toLocaleDateString('de-CH', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const wordCount = post.body?.split(/\s+/).length ?? 0;
const readingMinutes = Math.max(1, Math.ceil(wordCount / 200));

const allDePosts = await getCollection('blog', ({ data }) => data.lang === 'de' && !data.draft);

const blogPostingSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  url: canonical,
  datePublished: date.toISOString(),
  dateModified: date.toISOString(),
  author: {
    '@type': 'Person',
    name: author ?? 'DriveBuddies',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Drive Buddies Fahrschule',
    url: site,
    logo: {
      '@type': 'ImageObject',
      url: `${site}/logo-icon.png`,
    },
  },
  image: cover ? (cover.startsWith('http') ? cover : `${site}${cover}`) : `${site}/og-default.png`,
  inLanguage: 'de-CH',
  timeRequired: `PT${readingMinutes}M`,
  keywords: tags.join(', '),
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${site}/blog/` },
    { '@type': 'ListItem', position: 3, name: title, item: canonical },
  ],
};
---

<Layout
  title={post.data.seoTitle ?? `${title} | DriveBuddies`}
  description={post.data.seoDescription ?? description}
  canonical={canonical}
  hreflangDe={canonical}
  hreflangEn={`${site}/en/blog/${enSlug}/`}
  image={cover}
  jsonLd={[blogPostingSchema, breadcrumbSchema]}
>
  <article class="post">
    <header class="post__header">
      <div class="post__header-inner">
        <nav class="post__breadcrumb" aria-label="Breadcrumb">
          <ol>
            <li><a href="/">Home</a></li>
            <li aria-hidden="true">›</li>
            <li><a href="/blog/">Blog</a></li>
            <li aria-hidden="true">›</li>
            <li aria-current="page">{title}</li>
          </ol>
        </nav>

        {tags.length > 0 && (
          <ul class="post__tags" aria-label="Schlagwörter">
            {tags.map((tag) => (
              <li>
                <a href={`/blog/tags/${encodeURIComponent(tag)}/`} class="post__tag">{tag}</a>
              </li>
            ))}
          </ul>
        )}

        <h1 class="post__title">{title}</h1>
        <p class="post__desc">{description}</p>

        <div class="post__meta">
          {author && <span class="post__author">{author}</span>}
          <time datetime={date.toISOString()} class="post__date">{formattedDate}</time>
          <span class="post__reading">{readingMinutes} Min. Lesezeit</span>
        </div>
      </div>
    </header>

    {cover && (
      <div class="post__cover-wrap">
        <img
          src={cover}
          alt=""
          class="post__cover"
          loading="eager"
          decoding="async"
          width="1200"
          height="675"
        />
      </div>
    )}

    <div class="post__content-wrap">
      <div class="post__content prose">
        <Content />
      </div>

      <aside class="post__sidebar">
        <div class="post__sidebar-widget">
          <h2 class="post__sidebar-heading">Themen</h2>
          <ul class="post__tag-list">
            {tags.map((tag) => (
              <li>
                <a href={`/blog/tags/${encodeURIComponent(tag)}/`} class="post__tag">{tag}</a>
              </li>
            ))}
          </ul>
        </div>
        <div class="post__sidebar-widget">
          <p class="post__reading-large">{readingMinutes} Min.<br /><small>Lesezeit</small></p>
        </div>
      </aside>
    </div>

    <div class="post__related-wrap">
      <RelatedPosts
        currentId={post.id}
        currentTags={tags}
        allPosts={allDePosts}
        lang="de"
      />
    </div>
  </article>
</Layout>

<style>
  .post__header {
    background: var(--color-surface-alt);
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-12) 0 var(--space-10);
  }

  .post__header-inner {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 var(--space-6);
  }

  .post__breadcrumb ol {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-6);
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .post__breadcrumb a {
    color: var(--color-primary);
    text-decoration: none;
  }

  .post__breadcrumb a:hover {
    text-decoration: underline;
  }

  .post__tags {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-4);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .post__tag {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary);
    text-decoration: none;
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-sm);
  }

  .post__tag:hover {
    background: color-mix(in srgb, var(--color-primary) 20%, transparent);
  }

  .post__title {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 800;
    line-height: 1.25;
    margin: 0 0 var(--space-4);
    color: var(--color-text);
  }

  .post__desc {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0 0 var(--space-6);
  }

  .post__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .post__author {
    font-weight: 600;
    color: var(--color-text);
  }

  .post__author::after,
  .post__date::after {
    content: '·';
    margin-left: var(--space-2);
  }

  .post__cover-wrap {
    max-width: 960px;
    margin: var(--space-8) auto 0;
    padding: 0 var(--space-6);
  }

  .post__cover {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    display: block;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .post__content-wrap {
    max-width: 1100px;
    margin: var(--space-10) auto 0;
    padding: 0 var(--space-6);
    display: grid;
    grid-template-columns: 1fr 220px;
    gap: var(--space-12);
    align-items: start;
  }

  @media (max-width: 820px) {
    .post__content-wrap {
      grid-template-columns: 1fr;
    }
    .post__sidebar {
      display: none;
    }
  }

  /* Prose styles */
  .prose {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--color-text);
  }

  .prose :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    margin: var(--space-10) 0 var(--space-4);
    color: var(--color-text);
  }

  .prose :global(h3) {
    font-size: 1.25rem;
    font-weight: 700;
    margin: var(--space-8) 0 var(--space-3);
    color: var(--color-text);
  }

  .prose :global(p) {
    margin: 0 0 var(--space-6);
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: var(--space-6);
    margin: 0 0 var(--space-6);
  }

  .prose :global(li) {
    margin-bottom: var(--space-2);
  }

  .prose :global(strong) {
    font-weight: 700;
    color: var(--color-text);
  }

  .prose :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--color-primary) 40%, transparent);
    text-underline-offset: 3px;
  }

  .prose :global(a:hover) {
    text-decoration-color: var(--color-primary);
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-primary);
    padding-left: var(--space-6);
    margin: var(--space-8) 0;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-10) 0;
  }

  /* Sidebar */
  .post__sidebar {
    position: sticky;
    top: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .post__sidebar-widget {
    background: var(--color-surface-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-4);
  }

  .post__sidebar-heading {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-3);
  }

  .post__tag-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .post__reading-large {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-primary);
    margin: 0;
    line-height: 1.2;
  }

  .post__reading-large small {
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--color-text-muted);
  }

  .post__related-wrap {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 var(--space-6) var(--space-16);
  }
</style>
