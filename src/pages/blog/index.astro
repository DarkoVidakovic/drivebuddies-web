---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/blog/PostCard.astro';

const site = 'https://drivebuddies.ch';

const posts = (await getCollection('blog', ({ data }) => data.lang === 'de' && !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();

const title = 'Blog – Fahrschule Tipps & Wissen | DriveBuddies';
const description = 'Praxistipps und Wissen rund um Theorie, Praxis und Fahrprüfung. Der DriveBuddies-Blog für angehende Fahrerinnen und Fahrer.';
const canonical = `${site}/blog/`;

const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'DriveBuddies Blog',
  description,
  url: canonical,
  publisher: {
    '@type': 'Organization',
    name: 'Drive Buddies Fahrschule',
    url: site,
  },
  blogPost: posts.map((p) => ({
    '@type': 'BlogPosting',
    headline: p.data.title,
    url: `${site}/blog/${p.id}/`,
    datePublished: p.data.date.toISOString(),
    author: { '@type': 'Person', name: p.data.author ?? 'DriveBuddies' },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: canonical },
  ],
};
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  hreflangDe={canonical}
  hreflangEn={`${site}/en/blog/`}
  jsonLd={[blogSchema, breadcrumbSchema]}
>
  <section class="blog-hero">
    <div class="blog-hero__inner">
      <p class="blog-hero__eyebrow">Besser fahren, clever lernen</p>
      <h1 class="blog-hero__title">Blog</h1>
      <p class="blog-hero__lead">Praxistipps und Wissen rund um Theorie, Praxis und Fahrprüfung.</p>
    </div>
  </section>

  <div class="blog-layout">
    <main class="blog-layout__posts">
      {posts.length === 0 ? (
        <p class="blog-empty">Noch keine Beiträge vorhanden.</p>
      ) : (
        <div class="post-grid">
          {posts.map((post) => <PostCard post={post} lang="de" />)}
        </div>
      )}
    </main>

    <aside class="blog-layout__sidebar">
      <div class="sidebar-widget">
        <h2 class="sidebar-widget__title">Themen</h2>
        <ul class="tag-list">
          {allTags.map((tag) => (
            <li>
              <a href={`/blog/tags/${encodeURIComponent(tag)}/`} class="tag-list__item">{tag}</a>
            </li>
          ))}
        </ul>
      </div>
      <div class="sidebar-widget">
        <a href="/rss.xml" class="rss-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
          </svg>
          RSS-Feed abonnieren
        </a>
      </div>
    </aside>
  </div>
</Layout>

<style>
  .blog-hero {
    background: var(--color-surface-alt);
    padding: var(--space-16) 0 var(--space-12);
    border-bottom: 1px solid var(--color-border);
  }

  .blog-hero__inner {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 var(--space-6);
  }

  .blog-hero__eyebrow {
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary);
    margin: 0 0 var(--space-3);
  }

  .blog-hero__title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    margin: 0 0 var(--space-4);
    color: var(--color-text);
  }

  .blog-hero__lead {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .blog-layout {
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--space-12) var(--space-6);
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: var(--space-12);
    align-items: start;
  }

  @media (max-width: 900px) {
    .blog-layout {
      grid-template-columns: 1fr;
    }
    .blog-layout__sidebar {
      order: -1;
    }
  }

  .post-grid {
    display: grid;
    gap: var(--space-8);
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  }

  .blog-empty {
    color: var(--color-text-muted);
    font-size: 1rem;
  }

  .sidebar-widget {
    background: var(--color-surface-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    margin-bottom: var(--space-6);
  }

  .sidebar-widget__title {
    font-size: 0.9375rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-4);
  }

  .tag-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .tag-list__item {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    transition: background 0.15s;
  }

  .tag-list__item:hover {
    background: color-mix(in srgb, var(--color-primary) 20%, transparent);
  }

  .rss-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .rss-link:hover {
    color: var(--color-primary);
  }
</style>
