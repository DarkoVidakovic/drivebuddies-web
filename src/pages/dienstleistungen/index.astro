---
import Layout from '../../layouts/Layout.astro';
import Section from '../../components/ui/Section.astro';
import Icon from '../../components/ui/Icon.astro';
import WhatsAppButton from '../../components/ui/WhatsAppButton.astro';
import Button from '../../components/ui/Button.astro';
import { useTranslations } from '../../i18n/index.ts';

const locale = 'de';
const t = useTranslations(locale);
const s = t.services;
const site = 'https://drivebuddies.ch';

const services = [
  {
    icon: 'car' as const,
    title: 'Auto – Kat. B',
    text: s.auto.lead,
    href: '/dienstleistungen/auto/',
    cta: 'Mehr erfahren',
    badge: 'Schalt & Automat',
  },
  {
    icon: 'motorcycle' as const,
    title: 'Motorrad – Kat. A',
    text: s.motorrad.lead,
    href: '/dienstleistungen/motorrad/',
    cta: 'Mehr erfahren',
    badge: 'A1 / A35kW / A',
  },
  {
    icon: 'trailer' as const,
    title: 'Anhänger – Kat. BE',
    text: s.anhaenger.lead,
    href: '/dienstleistungen/anhaenger/',
    cta: 'Mehr erfahren',
    badge: 'Rangieren & Fahren',
  },
];

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Fahrausbildungen DriveBuddies',
  description: s.seoDescription,
  url: `${site}/dienstleistungen/`,
  itemListElement: services.map((svc, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: svc.title,
    url: `${site}${svc.href}`,
  })),
};
---

<Layout
  title={s.seoTitle}
  description={s.seoDescription}
  locale={locale}
  hreflangDe={`${site}/dienstleistungen/`}
  hreflangEn={`${site}/en/services/`}
  jsonLd={itemListSchema}
>
  <Section>
    <div class="overview__head">
      <span class="overview__eyebrow">{s.eyebrow}</span>
      <h1 class="overview__title">{s.title}</h1>
      <p class="overview__subtitle">{s.subtitle}</p>
    </div>
    <ul class="overview__grid">
      {
        services.map((svc) => (
          <li>
            <a class="svc-card" href={svc.href}>
              <span class="svc-card__badge">{svc.badge}</span>
              <span class="svc-card__icon">
                <Icon name={svc.icon} />
              </span>
              <h2 class="svc-card__title">{svc.title}</h2>
              <p class="svc-card__text">{svc.text}</p>
              <span class="svc-card__cta">
                {svc.cta}
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M5 12h14M13 6l6 6-6 6" />
                </svg>
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </Section>

  <Section variant="alt">
    <div class="cta-band">
      <p class="cta-band__text">Noch Fragen? Wir beraten dich gerne persönlich.</p>
      <div class="cta-band__actions">
        <Button href="/kontakt/" variant="primary" size="lg">Kontakt aufnehmen</Button>
        <WhatsAppButton label={s.ctaWhatsapp} message="Ich interessiere mich für eine Fahrausbildung bei DriveBuddies. Bitte nehmt Kontakt mit mir auf." />
      </div>
    </div>
  </Section>
</Layout>

<style>
  .overview__head {
    text-align: center;
    max-width: 60ch;
    margin: 0 auto var(--space-12);
  }

  .overview__eyebrow {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: var(--space-3);
  }

  .overview__title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: var(--space-4);
  }

  .overview__subtitle {
    color: var(--color-text-muted);
    font-size: 1.125rem;
    margin: 0;
  }

  .overview__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-6);
  }

  .svc-card {
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: var(--space-8);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--color-text);
    transition: box-shadow 0.15s ease, transform 0.15s ease, border-color 0.15s ease;
  }

  .svc-card:hover,
  .svc-card:focus-visible {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
    border-color: var(--color-primary-light);
  }

  .svc-card:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .svc-card__badge {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
  }

  .svc-card__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--space-12);
    height: var(--space-12);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
    color: var(--color-primary);
    margin-bottom: var(--space-6);
  }

  .svc-card__icon :global(.icon) {
    width: 28px;
    height: 28px;
  }

  .svc-card__title {
    font-size: 1.375rem;
    font-weight: 700;
    margin-bottom: var(--space-3);
  }

  .svc-card__text {
    color: var(--color-text-muted);
    margin: 0 0 var(--space-6);
    flex: 1;
    line-height: 1.6;
  }

  .svc-card__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-primary);
    font-weight: 600;
  }

  .svc-card:hover .svc-card__cta svg {
    transform: translateX(3px);
  }

  .svc-card__cta svg {
    transition: transform 0.15s ease;
  }

  .cta-band {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-8);
    text-align: center;
  }

  .cta-band__text {
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    font-weight: 700;
    margin: 0;
  }

  .cta-band__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    justify-content: center;
  }
</style>
