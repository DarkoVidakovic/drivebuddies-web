---
import Layout from '../../layouts/Layout.astro';
import Section from '../../components/ui/Section.astro';
import Button from '../../components/ui/Button.astro';
import WhatsAppButton from '../../components/ui/WhatsAppButton.astro';
import { useTranslations } from '../../i18n/index.ts';

const locale = 'de';
const t = useTranslations(locale);
const s = t.services;
const a = s.anhaenger;
const site = 'https://drivebuddies.ch';

const courseSchema = {
  '@context': 'https://schema.org',
  '@type': 'Course',
  name: 'Anhänger-Ausbildung Kategorie BE',
  description: a.seoDescription,
  url: `${site}/dienstleistungen/anhaenger/`,
  inLanguage: 'de-CH',
  courseMode: 'onsite',
  provider: { '@id': `${site}/#organization` },
  hasCourseInstance: {
    '@type': 'CourseInstance',
    name: 'Anhänger Kat. BE – Fahrstunden & Rangierparcours',
    courseMode: 'onsite',
    inLanguage: ['de-CH', 'en'],
  },
};
---

<Layout
  title={a.seoTitle}
  description={a.seoDescription}
  locale={locale}
  hreflangDe={`${site}/dienstleistungen/anhaenger/`}
  hreflangEn={`${site}/en/services/trailer/`}
  jsonLd={courseSchema}
>
  <Section>
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol class="breadcrumb__list">
        <li><a href="/">Startseite</a></li>
        <li><a href="/dienstleistungen/">{s.eyebrow}</a></li>
        <li aria-current="page">Anhänger – Kat. BE</li>
      </ol>
    </nav>

    <div class="detail__head">
      <span class="detail__eyebrow">{a.eyebrow}</span>
      <h1 class="detail__title">{a.title}</h1>
      <p class="detail__lead">{a.lead}</p>
    </div>

    <div class="info-grid">
      <div class="info-card">
        <div class="info-card__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" />
          </svg>
        </div>
        <h2 class="info-card__title">{a.requiresTitle}</h2>
        <p class="info-card__text">{a.requiresText}</p>
      </div>
      <div class="info-card info-card--accent">
        <div class="info-card__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="7" width="20" height="14" rx="2" /><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2" />
          </svg>
        </div>
        <h2 class="info-card__title">{a.contentTitle}</h2>
        <p class="info-card__text">{a.contentText}</p>
      </div>
    </div>
  </Section>

  <Section variant="alt">
    <div class="included">
      <h2 class="included__title">{s.includesList}</h2>
      <ul class="included__list">
        {a.included.map((item) => (
          <li class="included__item">
            <svg class="included__check" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="20 6 9 17 4 12" />
            </svg>
            {item}
          </li>
        ))}
      </ul>
    </div>
  </Section>

  <Section>
    <div class="cta-band">
      <p class="cta-band__text">Bereit für die Anhänger-Prüfung?</p>
      <div class="cta-band__actions">
        <Button href="/kontakt/" variant="primary" size="lg">{s.ctaContact}</Button>
        <WhatsAppButton label={s.ctaWhatsapp} message={a.ctaWhatsappMessage} />
      </div>
      <a href="/dienstleistungen/" class="cta-band__back">← {s.backToServices}</a>
    </div>
  </Section>
</Layout>

<style>
  .breadcrumb {
    margin-bottom: var(--space-10);
  }

  .breadcrumb__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .breadcrumb__list li + li::before {
    content: '/';
    margin-right: var(--space-2);
  }

  .breadcrumb__list a {
    color: var(--color-primary);
    text-decoration: none;
  }

  .breadcrumb__list a:hover {
    text-decoration: underline;
  }

  .detail__head {
    max-width: 70ch;
    margin-bottom: var(--space-12);
  }

  .detail__eyebrow {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: var(--space-3);
  }

  .detail__title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: var(--space-6);
  }

  .detail__lead {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0;
  }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-6);
  }

  .info-card {
    padding: var(--space-8);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
  }

  .info-card--accent {
    border-color: var(--color-primary-light);
    background: color-mix(in srgb, var(--color-primary) 5%, var(--color-surface));
  }

  .info-card__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--space-12);
    height: var(--space-12);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
    color: var(--color-primary);
    margin-bottom: var(--space-6);
  }

  .info-card__title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: var(--space-4);
  }

  .info-card__text {
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0;
  }

  .included {
    max-width: 60ch;
    margin: 0 auto;
  }

  .included__title {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: var(--space-8);
  }

  .included__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .included__item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    line-height: 1.5;
  }

  .included__check {
    flex-shrink: 0;
    color: var(--color-success);
    margin-top: 2px;
  }

  .cta-band {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
    text-align: center;
  }

  .cta-band__text {
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    font-weight: 700;
    margin: 0;
  }

  .cta-band__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    justify-content: center;
  }

  .cta-band__back {
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    text-decoration: none;
  }

  .cta-band__back:hover {
    color: var(--color-primary);
    text-decoration: underline;
  }
</style>
