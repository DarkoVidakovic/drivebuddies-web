---
import Layout from '../../../layouts/Layout.astro';
import Section from '../../../components/ui/Section.astro';
import Button from '../../../components/ui/Button.astro';
import WhatsAppButton from '../../../components/ui/WhatsAppButton.astro';
import { useTranslations } from '../../../i18n/index.ts';

const locale = 'en';
const t = useTranslations(locale);
const s = t.services;
const m = s.motorrad;
const site = 'https://drivebuddies.ch';

const courseSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Course',
    name: 'Motorcycle Grundkurs A1 (125cc)',
    description: 'Grundkurs for motorcycle category A1 – light motorcycle up to 125 cc and 11 kW.',
    url: `${site}/en/services/motorcycle/`,
    inLanguage: 'en',
    courseMode: 'onsite',
    provider: { '@id': `${site}/#organization` },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Course',
    name: 'Motorcycle Grundkurs A (35kW / unrestricted)',
    description: 'Grundkurs for motorcycle category A – 35 kW or unrestricted.',
    url: `${site}/en/services/motorcycle/`,
    inLanguage: 'en',
    courseMode: 'onsite',
    provider: { '@id': `${site}/#organization` },
  },
];
---

<Layout
  title={m.seoTitle}
  description={m.seoDescription}
  locale={locale}
  hreflangDe={`${site}/dienstleistungen/motorrad/`}
  hreflangEn={`${site}/en/services/motorcycle/`}
  jsonLd={courseSchema}
>
  <Section>
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol class="breadcrumb__list">
        <li><a href="/en/">Home</a></li>
        <li><a href="/en/services/">{s.eyebrow}</a></li>
        <li aria-current="page">Motorcycle – Cat. A</li>
      </ol>
    </nav>

    <div class="detail__head">
      <span class="detail__eyebrow">{m.eyebrow}</span>
      <h1 class="detail__title">{m.title}</h1>
      <p class="detail__lead">{m.lead}</p>
    </div>

    <div class="levels-grid">
      <div class="level-card">
        <div class="level-card__badge">A1</div>
        <h2 class="level-card__title">{m.a1Title}</h2>
        <p class="level-card__text">{m.a1Text}</p>
      </div>
      <div class="level-card level-card--featured">
        <div class="level-card__badge">A</div>
        <h2 class="level-card__title">{m.aTitle}</h2>
        <p class="level-card__text">{m.aText}</p>
      </div>
    </div>
  </Section>

  <Section variant="alt">
    <div class="training-types">
      <div class="training-type">
        <div class="training-type__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2L2 7l10 5 10-5-10-5z" /><path d="M2 17l10 5 10-5" /><path d="M2 12l10 5 10-5" />
          </svg>
        </div>
        <h2 class="training-type__title">{m.grundkursTitle}</h2>
        <p class="training-type__text">{m.grundkursText}</p>
      </div>
      <div class="training-type">
        <div class="training-type__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" />
          </svg>
        </div>
        <h2 class="training-type__title">{m.fahrstundenTitle}</h2>
        <p class="training-type__text">{m.fahrstundenText}</p>
      </div>
    </div>
  </Section>

  <Section>
    <div class="included">
      <h2 class="included__title">{s.includesList}</h2>
      <ul class="included__list">
        {m.included.map((item) => (
          <li class="included__item">
            <svg class="included__check" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="20 6 9 17 4 12" />
            </svg>
            {item}
          </li>
        ))}
      </ul>
    </div>
  </Section>

  <Section variant="alt">
    <div class="cta-band">
      <p class="cta-band__text">Ready for your first ride?</p>
      <div class="cta-band__actions">
        <Button href="/en/contact/" variant="primary" size="lg">{s.ctaContact}</Button>
        <WhatsAppButton label={s.ctaWhatsapp} message={m.ctaWhatsappMessage} />
      </div>
      <a href="/en/services/" class="cta-band__back">← {s.backToServices}</a>
    </div>
  </Section>
</Layout>

<style>
  .breadcrumb { margin-bottom: var(--space-10); }
  .breadcrumb__list {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-wrap: wrap; gap: var(--space-2);
    font-size: 0.875rem; color: var(--color-text-muted);
  }
  .breadcrumb__list li + li::before { content: '/'; margin-right: var(--space-2); }
  .breadcrumb__list a { color: var(--color-primary); text-decoration: none; }
  .breadcrumb__list a:hover { text-decoration: underline; }

  .detail__head { max-width: 70ch; margin-bottom: var(--space-12); }
  .detail__eyebrow {
    display: inline-block; font-size: 0.875rem; font-weight: 600;
    letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--color-primary); margin-bottom: var(--space-3);
  }
  .detail__title { font-size: clamp(2rem, 4vw, 3rem); font-weight: 800; line-height: 1.15; margin-bottom: var(--space-6); }
  .detail__lead { font-size: 1.125rem; color: var(--color-text-muted); line-height: 1.7; margin: 0; }

  .levels-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--space-6); }
  .level-card {
    padding: var(--space-8); border: 1px solid var(--color-border);
    border-radius: var(--radius-lg); background: var(--color-surface);
  }
  .level-card--featured {
    border-color: var(--color-primary-light);
    background: color-mix(in srgb, var(--color-primary) 5%, var(--color-surface));
  }
  .level-card__badge {
    display: inline-block; font-size: 0.8125rem; font-weight: 700;
    color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 12%, transparent);
    padding: var(--space-1) var(--space-3); border-radius: var(--radius-full); margin-bottom: var(--space-4);
  }
  .level-card__title { font-size: 1.25rem; font-weight: 700; margin-bottom: var(--space-4); }
  .level-card__text { color: var(--color-text-muted); line-height: 1.65; margin: 0; }

  .training-types { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--space-8); }
  .training-type__icon {
    display: inline-flex; align-items: center; justify-content: center;
    width: var(--space-12); height: var(--space-12); border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
    color: var(--color-primary); margin-bottom: var(--space-4);
  }
  .training-type__title { font-size: 1.25rem; font-weight: 700; margin-bottom: var(--space-3); }
  .training-type__text { color: var(--color-text-muted); line-height: 1.65; margin: 0; }

  .included { max-width: 60ch; margin: 0 auto; }
  .included__title { font-size: 1.5rem; font-weight: 700; margin-bottom: var(--space-8); }
  .included__list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: var(--space-4); }
  .included__item { display: flex; align-items: flex-start; gap: var(--space-3); line-height: 1.5; }
  .included__check { flex-shrink: 0; color: var(--color-success); margin-top: 2px; }

  .cta-band { display: flex; flex-direction: column; align-items: center; gap: var(--space-6); text-align: center; }
  .cta-band__text { font-size: clamp(1.25rem, 2vw, 1.5rem); font-weight: 700; margin: 0; }
  .cta-band__actions { display: flex; flex-wrap: wrap; gap: var(--space-4); justify-content: center; }
  .cta-band__back { color: var(--color-text-muted); font-size: 0.9375rem; text-decoration: none; }
  .cta-band__back:hover { color: var(--color-primary); text-decoration: underline; }
</style>
