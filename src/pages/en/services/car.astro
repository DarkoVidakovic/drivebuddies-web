---
import Layout from '../../../layouts/Layout.astro';
import Section from '../../../components/ui/Section.astro';
import Button from '../../../components/ui/Button.astro';
import WhatsAppButton from '../../../components/ui/WhatsAppButton.astro';
import { useTranslations } from '../../../i18n/index.ts';

const locale = 'en';
const t = useTranslations(locale);
const s = t.services;
const a = s.auto;
const site = 'https://drivebuddies.ch';

const courseSchema = {
  '@context': 'https://schema.org',
  '@type': 'Course',
  name: 'Car Driving Training Category B',
  description: a.seoDescription,
  url: `${site}/en/services/car/`,
  inLanguage: 'en',
  courseMode: 'onsite',
  provider: { '@id': `${site}/#organization` },
  hasCourseInstance: [
    {
      '@type': 'CourseInstance',
      name: 'Manual gearbox',
      courseMode: 'onsite',
      inLanguage: ['de-CH', 'en'],
    },
    {
      '@type': 'CourseInstance',
      name: 'Automatic gearbox',
      courseMode: 'onsite',
      inLanguage: ['de-CH', 'en'],
    },
  ],
};
---

<Layout
  title={a.seoTitle}
  description={a.seoDescription}
  locale={locale}
  hreflangDe={`${site}/dienstleistungen/auto/`}
  hreflangEn={`${site}/en/services/car/`}
  jsonLd={courseSchema}
>
  <Section>
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol class="breadcrumb__list">
        <li><a href="/en/">Home</a></li>
        <li><a href="/en/services/">{s.eyebrow}</a></li>
        <li aria-current="page">Car – Cat. B</li>
      </ol>
    </nav>

    <div class="detail__head">
      <span class="detail__eyebrow">{a.eyebrow}</span>
      <h1 class="detail__title">{a.title}</h1>
      <p class="detail__lead">{a.lead}</p>
    </div>

    <div class="transmission-grid">
      <div class="trans-card">
        <div class="trans-card__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="5" r="2" /><circle cx="12" cy="12" r="2" /><circle cx="12" cy="19" r="2" />
            <line x1="12" y1="7" x2="12" y2="10" /><line x1="12" y1="14" x2="12" y2="17" />
          </svg>
        </div>
        <h2 class="trans-card__title">{a.manualTitle}</h2>
        <p class="trans-card__text">{a.manualText}</p>
      </div>
      <div class="trans-card trans-card--accent">
        <div class="trans-card__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="3" />
            <path d="M8 12h8M12 8v8" />
          </svg>
        </div>
        <h2 class="trans-card__title">{a.automaticTitle}</h2>
        <p class="trans-card__text">{a.automaticText}</p>
      </div>
    </div>
  </Section>

  <Section variant="alt">
    <div class="included">
      <h2 class="included__title">{a.includedTitle}</h2>
      <ul class="included__list">
        {a.included.map((item) => (
          <li class="included__item">
            <svg class="included__check" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="20 6 9 17 4 12" />
            </svg>
            {item}
          </li>
        ))}
      </ul>
    </div>
  </Section>

  <Section>
    <div class="cta-band">
      <p class="cta-band__text">Ready to get started? Sign up today.</p>
      <div class="cta-band__actions">
        <Button href="/en/contact/" variant="primary" size="lg">{s.ctaContact}</Button>
        <WhatsAppButton label={s.ctaWhatsapp} message={a.ctaWhatsappMessage} />
      </div>
      <a href="/en/services/" class="cta-band__back">← {s.backToServices}</a>
    </div>
  </Section>
</Layout>

<style>
  .breadcrumb { margin-bottom: var(--space-10); }
  .breadcrumb__list {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-wrap: wrap; gap: var(--space-2);
    font-size: 0.875rem; color: var(--color-text-muted);
  }
  .breadcrumb__list li + li::before { content: '/'; margin-right: var(--space-2); }
  .breadcrumb__list a { color: var(--color-primary); text-decoration: none; }
  .breadcrumb__list a:hover { text-decoration: underline; }

  .detail__head { max-width: 70ch; margin-bottom: var(--space-12); }
  .detail__eyebrow {
    display: inline-block; font-size: 0.875rem; font-weight: 600;
    letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--color-primary); margin-bottom: var(--space-3);
  }
  .detail__title {
    font-size: clamp(2rem, 4vw, 3rem); font-weight: 800;
    line-height: 1.15; margin-bottom: var(--space-6);
  }
  .detail__lead { font-size: 1.125rem; color: var(--color-text-muted); line-height: 1.7; margin: 0; }

  .transmission-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--space-6);
  }
  .trans-card {
    padding: var(--space-8); border: 1px solid var(--color-border);
    border-radius: var(--radius-lg); background: var(--color-surface);
  }
  .trans-card--accent {
    border-color: var(--color-primary-light);
    background: color-mix(in srgb, var(--color-primary) 5%, var(--color-surface));
  }
  .trans-card__icon {
    display: inline-flex; align-items: center; justify-content: center;
    width: var(--space-12); height: var(--space-12);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
    color: var(--color-primary); margin-bottom: var(--space-6);
  }
  .trans-card__title { font-size: 1.25rem; font-weight: 700; margin-bottom: var(--space-4); }
  .trans-card__text { color: var(--color-text-muted); line-height: 1.65; margin: 0; }

  .included { max-width: 60ch; margin: 0 auto; }
  .included__title { font-size: 1.5rem; font-weight: 700; margin-bottom: var(--space-8); }
  .included__list {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-direction: column; gap: var(--space-4);
  }
  .included__item { display: flex; align-items: flex-start; gap: var(--space-3); line-height: 1.5; }
  .included__check { flex-shrink: 0; color: var(--color-success); margin-top: 2px; }

  .cta-band {
    display: flex; flex-direction: column; align-items: center;
    gap: var(--space-6); text-align: center;
  }
  .cta-band__text { font-size: clamp(1.25rem, 2vw, 1.5rem); font-weight: 700; margin: 0; }
  .cta-band__actions { display: flex; flex-wrap: wrap; gap: var(--space-4); justify-content: center; }
  .cta-band__back { color: var(--color-text-muted); font-size: 0.9375rem; text-decoration: none; }
  .cta-band__back:hover { color: var(--color-primary); text-decoration: underline; }
</style>
