---
import Layout from '../../../layouts/Layout.astro';
import Section from '../../../components/ui/Section.astro';
import Button from '../../../components/ui/Button.astro';
import WhatsAppButton from '../../../components/ui/WhatsAppButton.astro';
import { useTranslations } from '../../../i18n/index.ts';

const locale = 'en';
const t = useTranslations(locale);
const p = t.kontrollfahrt;
const site = 'https://drivebuddies.ch';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${site}/en/` },
    { '@type': 'ListItem', position: 2, name: 'Mock Driving Test', item: `${site}/en/mock-driving-test/` },
  ],
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Kontrollfahrt – Mock Driving Test',
  description: p.lead,
  url: `${site}/en/mock-driving-test/`,
  inLanguage: 'en',
  provider: {
    '@type': 'DrivingSchool',
    name: 'Drive Buddies Fahrschule',
    url: site,
  },
  areaServed: { '@type': 'City', name: 'Zürich' },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: p.faq.items.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};
---

<Layout
  title={p.seoTitle}
  description={p.seoDescription}
  locale={locale}
  hreflangDe={`${site}/kontrollfahrt/`}
  hreflangEn={`${site}/en/mock-driving-test/`}
  jsonLd={[breadcrumbSchema, serviceSchema, faqSchema]}
>
  <Section>
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol class="breadcrumb__list">
        <li><a href="/en/">Home</a></li>
        <li aria-current="page">Kontrollfahrt</li>
      </ol>
    </nav>

    <div class="page__head">
      <span class="page__eyebrow">{p.eyebrow}</span>
      <h1 class="page__title">{p.title}</h1>
      <p class="page__lead">{p.lead}</p>
    </div>
  </Section>

  <!-- What + Facts -->
  <Section variant="alt">
    <div class="content-grid">
      <div class="content-col">
        <h2 class="section__title">{p.whatTitle}</h2>
        <p class="section__text">{p.whatText}</p>

        <h3 class="section__subtitle">{p.contentTitle}</h3>
        <ul class="check-list">
          {p.contentItems.map((item) => (
            <li class="check-list__item">
              <svg class="check-list__icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <aside class="facts-card">
        <h3 class="facts-card__title">{p.factsTitle}</h3>
        <dl class="facts-card__list">
          {p.facts.map((f) => (
            <div class="facts-card__row">
              <dt class="facts-card__label">{f.label}</dt>
              <dd class="facts-card__value">{f.value}</dd>
            </div>
          ))}
        </dl>
      </aside>
    </div>
  </Section>

  <!-- At DriveBuddies -->
  <Section>
    <div class="highlight-box">
      <h2 class="highlight-box__title">{p.atDbTitle}</h2>
      <p class="highlight-box__text">{p.atDbText}</p>
      <div class="highlight-box__actions">
        <Button href="/en/contact/" variant="primary">{p.ctaPrimary}</Button>
        <WhatsAppButton label={p.ctaWhatsapp} message={p.ctaWhatsappMessage} />
      </div>
    </div>
  </Section>

  <!-- FAQ -->
  <Section variant="alt">
    <div class="faq">
      <span class="faq__eyebrow">{p.faq.eyebrow}</span>
      <h2 class="faq__title">{p.faq.title}</h2>
      <dl class="faq__list">
        {p.faq.items.map((item) => (
          <div class="faq__item">
            <dt class="faq__question">{item.q}</dt>
            <dd class="faq__answer">{item.a}</dd>
          </div>
        ))}
      </dl>
    </div>
  </Section>

  <!-- Next step -->
  <Section>
    <div class="next-step">
      <h2 class="next-step__title">{p.nextTitle}</h2>
      <p class="next-step__text">{p.nextText}</p>
      <a href={p.nextHref} class="next-step__link">
        {p.nextLabel}
        <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
      </a>
    </div>
  </Section>
</Layout>

<style>
  .breadcrumb { margin-bottom: var(--space-10); }
  .breadcrumb__list { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; gap: var(--space-2); font-size: 0.875rem; color: var(--color-text-muted); }
  .breadcrumb__list li + li::before { content: '/'; margin-right: var(--space-2); }
  .breadcrumb__list a { color: var(--color-primary); text-decoration: none; }
  .breadcrumb__list a:hover { text-decoration: underline; }
  .page__head { max-width: 72ch; }
  .page__eyebrow { display: inline-block; font-size: 0.875rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-primary); margin-bottom: var(--space-3); }
  .page__title { font-size: clamp(2rem, 4vw, 3rem); font-weight: 800; line-height: 1.15; margin-bottom: var(--space-6); }
  .page__lead { font-size: 1.125rem; color: var(--color-text-muted); line-height: 1.7; margin: 0; }
  .content-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-10); }
  @media (min-width: 768px) { .content-grid { grid-template-columns: 1fr 300px; align-items: start; } }
  .section__title { font-size: clamp(1.375rem, 2vw, 1.75rem); font-weight: 700; margin-bottom: var(--space-6); }
  .section__subtitle { font-size: 1.125rem; font-weight: 700; margin-top: var(--space-8); margin-bottom: var(--space-4); }
  .section__text { color: var(--color-text-muted); line-height: 1.7; margin-bottom: var(--space-6); }
  .check-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: var(--space-3); }
  .check-list__item { display: flex; align-items: flex-start; gap: var(--space-3); line-height: 1.5; }
  .check-list__icon { flex-shrink: 0; color: var(--color-success); margin-top: 2px; }
  .facts-card { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: var(--space-8); align-self: start; }
  .facts-card__title { font-size: 1.125rem; font-weight: 700; margin-bottom: var(--space-6); padding-bottom: var(--space-4); border-bottom: 2px solid var(--color-primary); }
  .facts-card__list { display: flex; flex-direction: column; gap: var(--space-4); }
  .facts-card__row { display: flex; flex-direction: column; gap: var(--space-1); }
  .facts-card__label { font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-text-muted); }
  .facts-card__value { font-weight: 600; }
  .highlight-box { background: color-mix(in srgb, var(--color-primary) 6%, var(--color-surface)); border: 1px solid color-mix(in srgb, var(--color-primary) 20%, transparent); border-radius: var(--radius-lg); padding: var(--space-10); max-width: 72ch; }
  .highlight-box__title { font-size: 1.5rem; font-weight: 700; margin-bottom: var(--space-4); }
  .highlight-box__text { color: var(--color-text-muted); line-height: 1.7; margin-bottom: var(--space-8); }
  .highlight-box__actions { display: flex; flex-wrap: wrap; gap: var(--space-4); }
  .faq { max-width: 72ch; margin: 0 auto; }
  .faq__eyebrow { display: inline-block; font-size: 0.875rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-primary); margin-bottom: var(--space-3); }
  .faq__title { font-size: clamp(1.5rem, 2.5vw, 2rem); font-weight: 700; margin-bottom: var(--space-10); }
  .faq__list { display: flex; flex-direction: column; gap: var(--space-6); }
  .faq__item { border-left: 3px solid var(--color-primary); padding-left: var(--space-6); }
  .faq__question { font-size: 1rem; font-weight: 700; margin-bottom: var(--space-2); }
  .faq__answer { color: var(--color-text-muted); line-height: 1.65; margin: 0; }
  .next-step { display: flex; flex-direction: column; gap: var(--space-4); padding: var(--space-8); border: 1px solid var(--color-border); border-radius: var(--radius-lg); border-left: 4px solid var(--color-primary); max-width: 64ch; }
  .next-step__title { font-size: 1.25rem; font-weight: 700; margin: 0; }
  .next-step__text { color: var(--color-text-muted); line-height: 1.65; margin: 0; }
  .next-step__link { display: inline-flex; align-items: center; gap: var(--space-2); color: var(--color-primary); font-weight: 600; font-size: 0.9375rem; text-decoration: none; }
  .next-step__link:hover { text-decoration: underline; }
</style>
