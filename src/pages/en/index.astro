---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/ui/Button.astro';
import Section from '../../components/ui/Section.astro';
import { useTranslations } from '../../i18n/index.ts';

const t = useTranslations('en');
---

<Layout
  title={t.seo.homeTitle}
  description={t.seo.homeDescription}
  locale="en"
  hreflangDe="https://drivebuddies.ch/"
  hreflangEn="https://drivebuddies.ch/en/"
>
  <Section>
    <div class="hero">
      <h1 class="hero__title">DriveBuddies</h1>
      <p class="hero__subtitle">Your driving school in Zurich — modern, flexible, personal.</p>
      <div class="hero__actions">
        <Button href="/en/courses/" size="lg">{t.nav.courses}</Button>
        <Button href="/en/contact/" variant="secondary" size="lg">{t.nav.contact}</Button>
      </div>
    </div>
  </Section>
</Layout>

<style>
  .hero {
    text-align: center;
    padding-block: var(--space-12);
  }
  .hero__title {
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: var(--space-4);
  }
  .hero__subtitle {
    font-size: clamp(1rem, 2vw, 1.375rem);
    color: var(--color-text-muted);
    max-width: 60ch;
    margin-inline: auto;
    margin-bottom: var(--space-8);
  }
  .hero__actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
