---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/home/Hero.astro';
import UspHighlights from '../components/home/UspHighlights.astro';
import ServiceTeasers from '../components/home/ServiceTeasers.astro';
import RatingBand from '../components/home/RatingBand.astro';
import LicenceJourney from '../components/home/LicenceJourney.astro';
import InstructorIntro from '../components/home/InstructorIntro.astro';
import FaqTeaser from '../components/home/FaqTeaser.astro';
import FinalCta from '../components/home/FinalCta.astro';
import { useTranslations } from '../i18n/index.ts';
import { fetchPlaceRating, GOOGLE_MAPS_URL } from '../lib/googlePlaces.ts';

const locale = 'de';
const t = useTranslations(locale);
const site = 'https://drivebuddies.ch';
const { value: ratingValue, count: ratingCount } = await fetchPlaceRating();

// ── JSON-LD: WebSite + Organization (IA table) + FAQPage (FAQ teaser) ──────
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'DriveBuddies Fahrschule Zürich',
  url: `${site}/`,
  inLanguage: 'de-CH',
  publisher: { '@id': `${site}/#organization` },
};

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${site}/#organization`,
  name: 'Drive Buddies Fahrschule',
  url: `${site}/`,
  logo: `${site}/logo-icon.png`,
  sameAs: [
    'https://www.instagram.com/drive_buddies/',
    GOOGLE_MAPS_URL,
  ],
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: String(ratingValue),
    reviewCount: String(ratingCount),
    bestRating: '5',
    worstRating: '1',
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: t.home.faq.items.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};

const jsonLd = [websiteSchema, organizationSchema, faqSchema];
---

<Layout
  title={t.seo.homeTitle}
  description={t.seo.homeDescription}
  locale={locale}
  hreflangDe={`${site}/`}
  hreflangEn={`${site}/en/`}
  jsonLd={jsonLd}
>
  <Hero locale={locale} />
  <UspHighlights locale={locale} />
  <ServiceTeasers locale={locale} />
  <RatingBand locale={locale} />
  <LicenceJourney locale={locale} />
  <InstructorIntro locale={locale} />
  <FaqTeaser locale={locale} />
  <FinalCta locale={locale} />
</Layout>
