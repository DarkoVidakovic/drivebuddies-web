---
import Layout from '../layouts/Layout.astro';
import Button from '../components/ui/Button.astro';
import Section from '../components/ui/Section.astro';
---

<Layout title="DriveBuddies – Token Scratch Page">
  <!-- Hero Section -->
  <Section>
    <div class="hero">
      <h1 class="hero__title">DriveBuddies</h1>
      <p class="hero__subtitle">Ihre Fahrschule in Zürich — modern, flexibel, persönlich.</p>
      <div class="hero__actions">
        <Button href="/kurse/" size="lg">Kurse entdecken</Button>
        <Button href="/kontakt/" variant="secondary" size="lg">Kontakt aufnehmen</Button>
      </div>
    </div>
  </Section>

  <!-- Alt section to prove surface-alt token -->
  <Section variant="alt">
    <h2 class="section-title">Button Variants</h2>
    <div class="button-grid">
      <div class="button-group">
        <h3 class="button-group__label">Primary</h3>
        <Button size="sm">Small</Button>
        <Button size="md">Medium</Button>
        <Button size="lg">Large</Button>
      </div>
      <div class="button-group">
        <h3 class="button-group__label">Secondary</h3>
        <Button variant="secondary" size="sm">Small</Button>
        <Button variant="secondary" size="md">Medium</Button>
        <Button variant="secondary" size="lg">Large</Button>
      </div>
      <div class="button-group">
        <h3 class="button-group__label">Ghost</h3>
        <Button variant="ghost" size="sm">Small</Button>
        <Button variant="ghost" size="md">Medium</Button>
        <Button variant="ghost" size="lg">Large</Button>
      </div>
    </div>
  </Section>

  <!-- Dark section -->
  <Section variant="dark">
    <div class="cta">
      <h2 class="cta__title">Bereit anzufangen?</h2>
      <p class="cta__text">Melden Sie sich noch heute an und fahren Sie sicher mit DriveBuddies.</p>
      <Button href="/kontakt/" size="lg">Jetzt anmelden</Button>
    </div>
  </Section>

  <!-- Token reference -->
  <Section variant="alt">
    <h2 class="section-title">Design Token Reference</h2>
    <div class="token-grid">
      <div class="token-swatch" style="background:var(--color-primary)">
        <span>primary<br/>#1d68f4</span>
      </div>
      <div class="token-swatch" style="background:var(--color-primary-dark)">
        <span>primary-dark<br/>#155dcf</span>
      </div>
      <div class="token-swatch" style="background:var(--color-primary-light)">
        <span>primary-light<br/>#5a93f7</span>
      </div>
      <div class="token-swatch" style="background:var(--color-accent)">
        <span>accent<br/>#010101</span>
      </div>
      <div class="token-swatch token-swatch--light" style="background:var(--color-surface)">
        <span>surface<br/>#ffffff</span>
      </div>
      <div class="token-swatch token-swatch--light" style="background:var(--color-surface-alt)">
        <span>surface-alt<br/>#f5f5f5</span>
      </div>
      <div class="token-swatch" style="background:var(--color-success)">
        <span>success<br/>#027a48</span>
      </div>
      <div class="token-swatch" style="background:var(--color-error)">
        <span>error<br/>#b42318</span>
      </div>
    </div>
  </Section>
</Layout>

<style>
  .hero {
    text-align: center;
    padding-block: var(--space-12);
  }

  .hero__title {
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: var(--space-4);
  }

  .hero__subtitle {
    font-size: clamp(1rem, 2vw, 1.375rem);
    color: var(--color-text-muted);
    max-width: 60ch;
    margin-inline: auto;
    margin-bottom: var(--space-8);
  }

  .hero__actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  .section-title {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: var(--space-8);
  }

  .button-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-8);
  }

  .button-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    align-items: flex-start;
  }

  .button-group__label {
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }

  .cta {
    text-align: center;
  }

  .cta__title {
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 700;
    margin-bottom: var(--space-4);
  }

  .cta__text {
    color: rgba(255,255,255,0.75);
    margin-bottom: var(--space-8);
    font-size: 1.125rem;
  }

  .token-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: var(--space-4);
  }

  .token-swatch {
    border-radius: var(--radius-md);
    aspect-ratio: 1;
    display: flex;
    align-items: flex-end;
    padding: var(--space-3);
    box-shadow: var(--shadow-sm);
  }

  .token-swatch span {
    font-size: 0.75rem;
    font-weight: 600;
    color: white;
    line-height: 1.3;
  }

  .token-swatch--light span {
    color: var(--color-text-muted);
  }

  .token-swatch--light {
    border: 1px solid var(--color-border);
  }
</style>
