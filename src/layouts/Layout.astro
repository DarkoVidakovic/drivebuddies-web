---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SeoHead from '../components/SeoHead.astro';
import Icon from '../components/ui/Icon.astro';
import { useTranslations } from '../i18n/index.ts';
import type { Locale } from '../i18n/index.ts';
import { ogImageForPath } from '../i18n/routes.ts';

interface Props {
  title: string;
  description: string;
  locale?: Locale;
  canonical?: string;
  hreflangDe?: string;
  hreflangEn?: string;
  image?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  locale = 'de',
  canonical,
  hreflangDe,
  hreflangEn,
  image,
  noindex,
  jsonLd,
} = Astro.props;

const t = useTranslations(locale);
const waMessage = t.kontakt.floatingWhatsapp.message;
const waAriaLabel = t.kontakt.floatingWhatsapp.ariaLabel;
const waLabel = t.kontakt.floatingWhatsapp.label;
const waHref = `https://wa.me/41765861317?text=${encodeURIComponent(waMessage)}`;

const site = 'https://drivebuddies.ch';
const resolvedCanonical = canonical ?? new URL(Astro.url.pathname, site).href;
const htmlLang = locale === 'en' ? 'en' : 'de-CH';
// Default to the branded section OG image when a page doesn't set one.
const resolvedImage = image ?? ogImageForPath(Astro.url.pathname);
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <SeoHead
      title={title}
      description={description}
      canonical={resolvedCanonical}
      locale={locale}
      hreflangDe={hreflangDe}
      hreflangEn={hreflangEn}
      image={resolvedImage}
      noindex={noindex}
      jsonLd={jsonLd}
    />
  </head>
  <body>
    <a href="#main" class="skip-link">Zum Inhalt springen</a>
    <Nav locale={locale} />
    <main id="main">
      <slot />
    </main>
    <Footer locale={locale} />

    <!-- Floating WhatsApp button -->
    <a
      href={waHref}
      class="wa-float"
      target="_blank"
      rel="noopener noreferrer"
      aria-label={waAriaLabel}
    >
      <Icon name="whatsapp" class="wa-float__icon" />
      <span class="wa-float__label">{waLabel}</span>
    </a>
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    left: var(--space-4);
    top: -100px;
    z-index: 100;
    background: var(--color-primary);
    color: var(--color-surface);
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: top 0.15s;
  }
  .skip-link:focus {
    top: var(--space-4);
  }

  /* ── Floating WhatsApp button ─────────────────────────────────────────── */
  .wa-float {
    position: fixed;
    bottom: var(--space-6);
    right: var(--space-6);
    z-index: 50;
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    background: #25d366;
    color: #ffffff;
    border-radius: var(--radius-full);
    padding: var(--space-4) var(--space-6);
    text-decoration: none;
    font-weight: 700;
    font-size: 0.9375rem;
    box-shadow: var(--shadow-lg);
    /* hidden by default; JS reveals it after scroll or immediately on non-home pages */
    opacity: 0;
    pointer-events: none;
    transform: translateY(8px);
    transition: opacity 0.25s ease, transform 0.25s ease, background 0.15s, box-shadow 0.15s;
  }

  .wa-float.is-visible {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .wa-float:hover,
  .wa-float:focus-visible {
    background: #1aab52;
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(37,211,102,.35);
  }

  .wa-float:focus-visible {
    outline: 3px solid #ffffff;
    outline-offset: 3px;
  }

  .wa-float__icon {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }

  /* On mobile: icon-only circle, label hidden */
  @media (max-width: 639px) {
    .wa-float {
      padding: var(--space-4);
    }

    .wa-float__label {
      display: none;
    }

    .wa-float__icon {
      width: 26px;
      height: 26px;
    }
  }
</style>

<script>
  const btn = document.querySelector<HTMLAnchorElement>('.wa-float');
  if (btn) {
    const sentinel = document.querySelector('[data-wa-hide-sentinel]');
    if (sentinel) {
      // Home page: reveal once the hero scrolls out of view
      const obs = new IntersectionObserver(
        ([entry]) => {
          btn.classList.toggle('is-visible', !entry.isIntersecting);
        },
        { threshold: 0 }
      );
      obs.observe(sentinel);
    } else {
      // All other pages: show immediately
      btn.classList.add('is-visible');
    }
  }
</script>
